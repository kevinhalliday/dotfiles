{
  "suggest.autoTrigger": "always",
  "suggest.noselect": true,
  "pairs.enableCharacters": ["(", "[", "{", "<", "\"", "'"],
  "suggest.completionItemKindLabels": {
    "keyword": "\uf1de",
    "variable": "\ue79b",
    "value": "\uf89f",
    "operator": "\u03a8",
    "function": "\u0192",
    "reference": "\ufa46",
    "constant": "\uf8fe",
    "method": "\uf09a",
    "struct": "\ufb44",
    "class": "\uf0e8",
    "interface": "\uf417",
    "text": "\ue612",
    "enum": "\uf435",
    "enumMember": "\uf02b",
    "module": "\uf40d",
    "color": "\ue22b",
    "property": "\ue624",
    "field": "\uf9be",
    "unit": "\uf475",
    "event": "\ufacd",
    "file": "\uf723",
    "folder": "\uf114",
    "snippet": "\ue60b",
    "typeParameter": "\uf728",
    "default": "\uf29c"
  },
  "coc.source.dictionary.filetypes": ["text", "markdown"],
  "coc.source.word.filetypes": ["text", "markdown"],
  "diagnostic.enable": true,
  "typescript.showUnused": false,
  "prisma": {},
  "languageserver": {
    "nginx-language-server": {
      "command": "nginx-language-server",
      "filetypes": ["nginx"],
      "rootPatterns": ["nginx.conf", ".git"]
    }
  },
  "cairols.nileUseVenv": true,
  "cairols.nileVenvCommand": ". .venv/bin/activate",
  "cairols.useVenv": true,
  "cairols.venvCommand": ". .venv/bin/activate",
  "solidity.includePath": "lib",
  "solidity.includePath": "node_modules",
  "diagnostic-languageserver.formatters": {
    "black": {
      "command": "black",
      "args": ["black", "-q", "-"]
    },
    "isort": {
      "command": "isort",
      "args": ["-q", "-"]
    },
    "docformatter": {
      "command": "docformatter",
      "args": ["-"]
    }
  },
  "diagnostic-languageserver.filetypes": {
    "python": ["pylint", "mypy"],
    // it was being kind of annoying
    // "go": ["golangci-lint"],
    "sh": "shellcheck"
  },
  "diagnostic-languageserver.mergeConfig": true,
  "diagnostic-languageserver.debug": true,
  "diagnostic-languageserver.enable": true,
  "diagnostic-languageserver.trace.server": "verbose",
  "diagnostic-languageserver.linters": {
    "mypy": {
      "sourceName": "mypy",
      "command": "mypy",
      "args": [
        "--no-color-output",
        "--no-error-summary",
        "--show-column-numbers",
        "--ignore-missing-imports",
        "--follow-imports=silent",
        "%filepath"
      ],
      "formatPattern": [
        "^.*:(\\d+?):(\\d+?): ([a-z]+?): (.*)$",
        {
          "line": 1,
          "column": 2,
          "security": 3,
          "message": 4
        }
      ],
      "securities": {
        "error": "error"
      }
    },

    "golangci-lint": {
      "rootPatterns": ["go.mod"],
    },
    // was being annoying, using defaults
    // golangci-lint run -E goimports,sqlclosecheck,bodyclose,asciicheck,misspell,errorlint -e "errors.As" -e "errors.Is"
    // "golangci-lint": {
    //   "sourceName": "golangci-lint",
    //   "command": "golangci-lint",
    //   "rootPatterns": ["go.mod"],
    //   // seems .git does not always play nice, when go mod or go workspace is nested within
    //   // "rootPatterns": [ ".git", "go.mod"],
    //   // args borrowed from optimism
    //   "args": [
    //     "run",
    //     "-E",
    //     "goimports,sqlclosecheck,bodyclose,asciicheck,misspell,errorlint",
    //     "-e",
    //     "\"errors.As\"",
    //     "-e",
    //     "\"errors.Is\"",
    //     "--out-format",
    //     "json"
    //   ],
    //   "parseJson": {
    //     "sourceName": "Pos.Filename",
    //     "sourceNameFilter": true,
    //     "errorsRoot": "Issues",
    //     "line": "Pos.Line",
    //     "column": "Pos.Column",
    //     "message": "${Text} [${FromLinter}]",
    //   }
    // },

    "pylint": {
      "sourceName": "pylint",
      "command": "pylint",
      "debounce": 100,
      "args": [
        "--output-format",
        "text",
        "--score",
        "no",
        "--msg-template",
        "'{line}:{column}:{category}:{msg} ({msg_id}:{symbol})'",
        "%file"
      ],
      "formatPattern": [
        "^(\\d+?):(\\d+?):([a-z]+?):(.*)$",
        {
          "line": 1,
          "column": 2,
          "security": 3,
          "message": 4
        }
      ],
      // "rootPatterns": ["pyproject.toml", ".git"],
      "securities": {
        "informational": "hint",
        "refactor": "info",
        "convention": "info",
        "warning": "warning",
        "error": "error",
        "fatal": "error"
      },
      "offsetColumn": 1,
      "formatLines": 1
    }
  },
  "@ignored/coc-solidity.telemetry": true
}
